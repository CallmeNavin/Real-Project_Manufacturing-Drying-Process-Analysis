import pandas as pd
import numpy as np
df_sensor = pd.read_csv("sensor_data.csv")

# Formate date
df_sensor["timestamp"] = pd.to_datetime(df_sensor["timestamp"],day_first= True, errors="coerce")
df_sensor = (df_sensor.sort_values("timestamp").reset_index(drop=True))

# Basic sensor cleaning rules (based on operating & engineering logic)
temp_cols = [c for c in df_sensor.columns if c.startswith("TEMP")]
for col in temp_cols:
    df_sensor[col] = df_sensor[col].where(df_sensor[col].between(0,200))
    df_sensor["FEED_RATE"] = df_sensor["FEED_RATE"].where(df_sensor["FEED_RATE"].between(0,100))

# Business time logic
df_sensor["process_hour"] = (df_sensor["timestamp"] - pd.Timedelta(hours=6))
df_sensor["process_date"] = (df_sensor["process_hour"].dt.date)

def get_shift(hour):
    if 6 <= hour < 14:
        return "Shift A"
    elif 14 <= hour < 22:
        return "Shift B"
    else:
        return "Shift C"
df_sensor["shift"] = (df_sensor["process_hour"].dt.hour.apply(get_shift))

# Define drying condition
df_sensor["is_drying"] = ((df_sensor["TEMP_MAIN"] >= 165) & (df_sensor["FEED_STATUS"] == 1)).astype(int)

# QC classification file
df_qc = pd.read_csv("drying_classification.csv")
df_qc["start_time"] = pd.to_datetime(df_qc["start_time"], day_first= True, errors="coerce")
df_qc["end_time"] = pd.to_datetime(df_qc["end_time"], day_first= True, errors="coerce")

# Map QC to sensor timeline
df_sensor["drying_category"] = "Other"
for _, row in df_qc.iterrows():
    mask = ((df_sensor["timestamp"] >= row["start_time"]) & (df_sensor["timestamp"] <= row["end_time"]))
    df_sensor.loc[mask,"drying_category"] = "Special"

# Define drying type
df_sensor["drying_type"] = "Not drying"
mask_special = ((df_sensor["is_drying"] == 1) & (df_sensor["drying_category"] == "Special"))
